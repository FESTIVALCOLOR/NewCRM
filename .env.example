# Interior Studio CRM — Переменные окружения
# ВАЖНО: Создайте файл .env в корне проекта и заполните эти значения
# ВНИМАНИЕ: НЕ коммитьте .env файл в git! Только .env.example

# === Клиент ===
# URL API сервера (ОБЯЗАТЕЛЬНО HTTPS в production!)
API_BASE_URL=https://crm.festivalcolor.ru

# === Сервер (Docker Compose) ===
# PostgreSQL пароль (сгенерировать: openssl rand -base64 24)
POSTGRES_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD

# JWT Secret (ОБЯЗАТЕЛЬНО сгенерировать: openssl rand -hex 32)
# Сервер НЕ ЗАПУСТИТСЯ без этого значения!
SECRET_KEY=CHANGE_THIS_GENERATE_WITH_openssl_rand_hex_32

# Яндекс.Диск токен
YANDEX_DISK_TOKEN=

# CORS — список разрешённых источников (через запятую, без пробелов)
# ВАЖНО: Wildcard "*" запрещён при использовании credentials
ALLOWED_ORIGINS=https://crm.festivalcolor.ru
